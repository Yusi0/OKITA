{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OKITA",
  "version": "0.2.2",
  "identifier": "com.okita.canvas",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OKITA Player",
        "width": 960,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": [
          "mp4",
          "mkv",
          "webm",
          "avi",
          "mov",
          "ogv",
          "3gp"
        ],
        "name": "OKITA Video",
        "description": "Video file openable by OKITA Player",
        "role": "Viewer"
      },
      {
        "ext": [
          "gif",
          "webp",
          "png",
          "jpg",
          "jpeg"
        ],
        "name": "OKITA Image & Animation",
        "description": "Animated GIF/WebP and image file openable by OKITA Player",
        "role": "Viewer"
      },
      {
        "ext": [
          "mp3",
          "wav",
          "m4a",
          "flac",
          "aac",
          "ogg"
        ],
        "name": "OKITA Audio",
        "description": "Audio file openable by OKITA Player",
        "role": "Viewer"
      }
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ]
  }
}